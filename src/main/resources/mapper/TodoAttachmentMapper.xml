<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.todo.mapper.TodoAttachmentMapper">

    <resultMap id="TodoAttachmentResultMap" type="com.example.todo.model.TodoAttachment">
        <id property="id" column="id" />
        <result property="todoId" column="todo_id" />
        <result property="originalFilename" column="original_filename" />
        <result property="storedFilename" column="stored_filename" />
        <result property="contentType" column="content_type" />
        <result property="fileSize" column="file_size" />
        <result property="uploadedAt" column="uploaded_at" />
    </resultMap>

    <insert id="insert" parameterType="com.example.todo.model.TodoAttachment"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO todo_attachments (todo_id, original_filename, stored_filename, content_type, file_size, uploaded_at)
        VALUES (#{todoId}, #{originalFilename}, #{storedFilename}, #{contentType}, #{fileSize}, #{uploadedAt})
    </insert>

    <select id="findById" resultMap="TodoAttachmentResultMap">
        SELECT id, todo_id, original_filename, stored_filename, content_type, file_size, uploaded_at
        FROM todo_attachments
        WHERE id = #{id}
    </select>

    <select id="findByTodoId" resultMap="TodoAttachmentResultMap">
        SELECT id, todo_id, original_filename, stored_filename, content_type, file_size, uploaded_at
        FROM todo_attachments
        WHERE todo_id = #{todoId}
        ORDER BY uploaded_at DESC, id DESC
    </select>

    <delete id="deleteById">
        DELETE FROM todo_attachments
        WHERE id = #{id}
    </delete>

    <delete id="deleteByTodoId">
        DELETE FROM todo_attachments
        WHERE todo_id = #{todoId}
    </delete>

</mapper>
